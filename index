<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Epic Whack-a-Mole</title>

    <!-- ✅ FIXED: Google Font (must be in head, NOT inside style) -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap" rel="stylesheet">

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Poppins', sans-serif;
        }

        body {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 20px;
            overflow: hidden;
            position: relative;
        }

        .stars {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: -1;
        }

        .star {
            position: absolute;
            background: white;
            border-radius: 50%;
            animation: twinkle 3s infinite;
        }

        @keyframes twinkle {
            0%, 100% { opacity: 0.3; }
            50% { opacity: 1; }
        }

        .container {
            background: rgba(255, 255, 255, 0.15);
            border-radius: 25px;
            padding: 40px;
            backdrop-filter: blur(15px);
            width: 100%;
            max-width: 550px;
            text-align: center;
        }

        h1 {
            font-size: 3rem;
            color: #ffde59;
            margin-bottom: 20px;
        }

        .game-info {
            display: flex;
            justify-content: space-between;
            margin-bottom: 30px;
        }

        .score, .time {
            font-size: 1.5rem;
            color: white;
        }

        .board {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
        }

        .hole {
            height: 120px;
            background: #4e342e;
            border-radius: 50%;
            position: relative;
            overflow: hidden;
            cursor: pointer;
        }

        .mole {
            position: absolute;
            width: 80%;
            height: 80%;
            top: 100%;
            left: 10%;
            background: brown;
            border-radius: 50%;
            transition: 0.3s;
        }

        .mole.up {
            top: 10%;
        }

        button {
            margin-top: 20px;
            padding: 10px 25px;
            font-size: 1rem;
            border: none;
            border-radius: 30px;
            cursor: pointer;
            background: #ffde59;
        }

        .game-over {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.8);
            align-items: center;
            justify-content: center;
            flex-direction: column;
            color: white;
        }
    </style>
</head>

<body>

<div class="stars" id="stars"></div>

<div class="container">
    <h1>EPIC WHACK-A-MOLE</h1>

    <div class="game-info">
        <div class="score">Score: <span id="score">0</span></div>
        <div class="time">Time: <span id="time">30</span></div>
    </div>

    <div class="board" id="board"></div>

    <button id="startBtn">START GAME</button>
</div>

<div class="game-over" id="gameOver">
    <h2>GAME OVER</h2>
    <h1 id="finalScore">0</h1>
    <button onclick="location.reload()">Play Again</button>
</div>

<script>
window.onload = function () {

    let score = 0;
    let time = 30;
    let gameActive = false;

    const board = document.getElementById("board");
    const scoreDisplay = document.getElementById("score");
    const timeDisplay = document.getElementById("time");
    const startBtn = document.getElementById("startBtn");
    const gameOver = document.getElementById("gameOver");
    const finalScore = document.getElementById("finalScore");

    // create board
    function createBoard() {
        board.innerHTML = "";
        for (let i = 0; i < 9; i++) {
            let hole = document.createElement("div");
            hole.classList.add("hole");

            let mole = document.createElement("div");
            mole.classList.add("mole");

            hole.appendChild(mole);

            hole.addEventListener("click", () => {
                if (mole.classList.contains("up")) {
                    score += 10;
                    scoreDisplay.innerText = score;
                    mole.classList.remove("up");
                }
            });

            board.appendChild(hole);
        }
    }

    function randomMole() {
        if (!gameActive) return;

        let holes = document.querySelectorAll(".hole");
        let index = Math.floor(Math.random() * holes.length);
        let mole = holes[index].querySelector(".mole");

        mole.classList.add("up");

        setTimeout(() => {
            mole.classList.remove("up");
        }, 800);
    }

    function startGame() {
        score = 0;
        time = 30;
        gameActive = true;

        scoreDisplay.innerText = score;
        timeDisplay.innerText = time;

        createBoard();

        let gameTimer = setInterval(() => {
            time--;
            timeDisplay.innerText = time;

            if (time <= 0) {
                clearInterval(gameTimer);
                gameActive = false;
                gameOver.style.display = "flex";
                finalScore.innerText = score;
            }
        }, 1000);

        setInterval(randomMole, 700);
    }

    startBtn.addEventListener("click", startGame);

    // stars
    const stars = document.getElementById("stars");
    for (let i = 0; i < 50; i++) {
        let s = document.createElement("div");
        s.className = "star";
        s.style.left = Math.random() * 100 + "%";
        s.style.top = Math.random() * 100 + "%";
        s.style.width = "3px";
        s.style.height = "3px";
        stars.appendChild(s);
    }

    createBoard();
};
</script>

</body>
</html>
